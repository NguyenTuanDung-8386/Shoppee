# ==========================================
# BACKEND - Django
# ==========================================

# Môi trường ảo
backend/venv/
backend/env/

# File .env chứa mật khẩu - KHÔNG push lên
backend/.env

# Python cache
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Database SQLite (nếu có)
backend/db.sqlite3

# File media (ảnh upload của user)
backend/media/

# Django static files đã collect
backend/staticfiles/

# ==========================================
# FRONTEND - React / Vite / Node
# ==========================================

# Thư mục node_modules - KHÔNG push lên (rất nặng)
frontend/node_modules/

# File build output
frontend/dist/
frontend/.cache/
frontend/.parcel-cache/

# Vite logs
frontend/vite.config.js.timestamp-*
frontend/vite.config.ts.timestamp-*

# ==========================================
# CHUNG
# ==========================================

# File .env ở mọi nơi
.env
.env.*
!.env.example

# Hệ điều hành
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.user

# Log files
*.log
logs/